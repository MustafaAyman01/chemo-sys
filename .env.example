# ============================================================
# ChemCo ERP — Environment Variables
# Copy this file to .env and fill in your Supabase credentials
# NEVER commit .env to git
# ============================================================

# Supabase Project URL (from: Project Settings → API)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Anon Public Key (from: Project Settings → API)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# App
VITE_APP_NAME=ChemCo ERP
VITE_APP_VERSION=1.0.0
